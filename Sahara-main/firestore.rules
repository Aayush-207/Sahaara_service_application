rules_version = '2';

// ⚠️ DEVELOPMENT MODE - OPEN ACCESS FOR SEEDING
// This allows the seeder to populate the database
// 
// IMPORTANT: Before deploying to production:
// 1. Replace this file content with firestore.rules.prod
// 2. Deploy to Firebase Console
//
// Current Mode: DEVELOPMENT (Open Access)

service cloud.firestore {
  match /databases/{database}/documents {
    
    // DEVELOPMENT: Allow all reads and writes for seeding
    // This is TEMPORARY for development only
    match /{document=**} {
      allow read, write: if true;
    }
  }
}

// PRODUCTION RULES ARE SAVED IN: firestore.rules.prod
// Copy that file here when ready for production!
