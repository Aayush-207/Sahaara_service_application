rules_version = '2';

// ⚠️ DEVELOPMENT RULES - FOR SEEDING ONLY
// These rules allow open access for development and seeding
// DO NOT USE IN PRODUCTION!

service cloud.firestore {
  match /databases/{database}/documents {
    
    // DEVELOPMENT: Allow all reads and writes for seeding
    match /{document=**} {
      allow read, write: if true;
    }

    // Chat rooms collection - Explicit rules for development
    match /chat_rooms/{chatRoomId} {
      allow read, write: if true;
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }
  }
}
