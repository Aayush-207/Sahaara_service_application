rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow authenticated users to access their own data
    function isAuthenticated() {
      return request.auth.uid != null;
    }
    
    // Chat rooms - Allow authenticated users
    match /chat_rooms/{chatRoomId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false; // Don't allow deletion
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated();
        allow delete: if isAuthenticated();
      }
    }

    // Chats collection - Allow authenticated users
    match /chats/{chatId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false; // Don't allow deletion
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated();
        allow delete: if isAuthenticated();
      }
    }

    // Users collection
    match /users/{userId} {
      allow read: if true; // Public read for caregivers (so they can be browsed)
      allow write: if isAuthenticated(); // Allow authenticated users to write (for seeding caregivers)
      
      // Pets subcollection
      match /pets/{petId} {
        allow read, write: if isAuthenticated(); // Allow authenticated users for admin operations
      }
    }

    // Pets collection (top-level, if exists)
    match /pets/{petId} {
      allow read, write: if isAuthenticated();
    }

    // Bookings collection
    match /bookings/{bookingId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Reports collection
    match /reports/{reportId} {
      allow read, write: if isAuthenticated();
    }

    // Service Packages collection - publicly readable, authenticated users can write (for seeding)
    match /service_packages/{packageId} {
      allow read: if true; // Public read access for all users
      allow write: if isAuthenticated(); // Allow authenticated users to write (for seeding)
    }

    // Adoptable Pets collection - publicly readable, authenticated users can write (for seeding)
    match /adoptable_pets/{petId} {
      allow read: if true; // Public read access for all users
      allow write: if isAuthenticated(); // Allow authenticated users to write (for seeding)
    }

    // Reviews collection
    match /reviews/{reviewId} {
      allow read: if true; // Public read access
      allow write: if isAuthenticated();
    }

    // Messages collection
    match /messages/{messageId} {
      allow read, write: if isAuthenticated();
    }

    // Favorites collection
    match /favorites/{favoriteId} {
      allow read, write: if isAuthenticated();
    }

    // User favorites collection
    match /user_favorites/{favoriteId} {
      allow read, write: if isAuthenticated();
    }

    // Generic fallback - allow authenticated users (for development/seeding)
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}


